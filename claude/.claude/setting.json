{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(npm run dev)",
      "Bash(npm run test *)"
    ],
    "deny": [
      "Bash(git push *)"
    ]
  }
}

